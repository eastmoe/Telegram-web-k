{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "publicDirectory": "public",
    "https": {
      "enabled": false,
      "keyFile": "certs/server-key.pem",
      "certFile": "certs/server-cert.pem"
    }
  },
  "telegram": {
    "proxyEnabled": true,
    "httpProxy": "http://127.0.0.1:7890",
    "requestTimeoutMs": 30000,
    "maxRequestBytes": 67108864,
    "maxBufferedWebSocketBytes": 8388608
  }
}
